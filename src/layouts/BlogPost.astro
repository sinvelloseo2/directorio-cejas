---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroImageAlt } = Astro.props;

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
	...(heroImage ? { "image": `${SITE_URL}${heroImage.src}` } : {}),
	"author": {
		"@type": "Organization",
		"name": "Directorio Cejas",
		"url": SITE_URL,
	},
	"publisher": {
		"@type": "Organization",
		"name": "Directorio Cejas",
		"url": SITE_URL,
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": `${SITE_URL}${Astro.url.pathname}`,
	},
};
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<Breadcrumb items={[
						{ label: 'Inicio', href: '/' },
						{ label: 'Blog', href: '/blog/' },
						{ label: title },
					]} />
				</div>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt={heroImageAlt ?? ""} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated-on">
									&middot; Actualizado el <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0;
	}
	.hero-image {
		width: 100%;
	}
	.hero-image img {
		display: block;
		margin: 0 auto;
		max-width: 1020px;
	}
	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
		color: var(--text-muted);
	}
	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		color: var(--text);
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(strong) {
		color: var(--text);
	}
	.title {
		margin-bottom: 1.5em;
		padding: 1em 0;
		border-bottom: 1px solid var(--border);
	}
	.title h1 {
		margin: 0.5rem 0 0;
		font-size: 2.2rem;
	}
	.date {
		font-size: 0.82rem;
		color: var(--text-dim);
	}
	.last-updated-on {
		font-style: italic;
	}
</style>
