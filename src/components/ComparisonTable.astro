---
import { ciudades } from '../data/ciudades';

interface Props {
	tratamientoSlug: string;
}

const { tratamientoSlug } = Astro.props;

const rows = ciudades
	.map((ciudad) => {
		const t = ciudad.tratamientos.find((t) => t.slug === tratamientoSlug);
		if (!t) return null;
		return {
			ciudad: ciudad.nombre,
			ciudadSlug: ciudad.slug,
			precioMin: t.precioMin,
			precioMax: t.precioMax,
			profesionales: t.profesionales,
		};
	})
	.filter(Boolean)
	.sort((a, b) => a!.precioMin - b!.precioMin);
---

<div class="table-wrap">
	<table>
		<thead>
			<tr>
				<th>Ciudad</th>
				<th>Precio mín.</th>
				<th>Precio máx.</th>
				<th>Profesionales</th>
			</tr>
		</thead>
		<tbody>
			{rows.map((row) => row && (
				<tr>
					<td><a href={`/ciudades/${row.ciudadSlug}/`}>{row.ciudad}</a></td>
					<td class="price">{row.precioMin}€</td>
					<td class="price">{row.precioMax}€</td>
					<td>{row.profesionales}+</td>
				</tr>
			))}
		</tbody>
	</table>
</div>

<style>
	.table-wrap {
		overflow-x: auto;
	}
	table {
		width: 100%;
		border-collapse: collapse;
	}
	th {
		text-align: left;
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-dim);
		padding: 0.8rem 1rem;
		border-bottom: 1px solid var(--border);
		font-weight: 600;
	}
	td {
		padding: 0.9rem 1rem;
		font-size: 0.9rem;
		border-bottom: 1px solid var(--border);
		color: var(--text-muted);
	}
	td a {
		color: var(--text);
		font-weight: 600;
		text-decoration: none;
	}
	td a:hover {
		color: var(--accent);
	}
	td.price {
		color: var(--accent);
		font-weight: 700;
	}
	tr:hover td {
		background: var(--bg-card);
	}
</style>
