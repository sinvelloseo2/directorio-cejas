---
import type { Ciudad } from '../data/ciudades';

interface Props {
	ciudad: Ciudad;
}

const { ciudad } = Astro.props;
const totalProfesionales = ciudad.tratamientos.reduce((sum, t) => sum + t.profesionales, 0);
const precioMin = Math.min(...ciudad.tratamientos.map((t) => t.precioMin));
const precioMax = Math.max(...ciudad.tratamientos.map((t) => t.precioMax));
---

<a href={`/ciudades/${ciudad.slug}/`} class="city-card">
	<div class="city-header">
		<h3>{ciudad.nombre}</h3>
		<span class="city-comunidad">{ciudad.comunidad}</span>
	</div>
	<p class="city-desc">{ciudad.descripcion}</p>
	<div class="city-meta">
		<div class="meta-item">
			<span class="meta-value">{ciudad.tratamientos.length}</span>
			<span class="meta-label">Tratamientos</span>
		</div>
		<div class="meta-item">
			<span class="meta-value">{totalProfesionales}+</span>
			<span class="meta-label">Profesionales</span>
		</div>
		<div class="meta-item">
			<span class="meta-value">{precioMin}€–{precioMax}€</span>
			<span class="meta-label">Rango precios</span>
		</div>
	</div>
</a>

<style>
	.city-card {
		display: block;
		background: var(--bg-card);
		border: 1px solid var(--border);
		padding: 1.8rem;
		text-decoration: none;
		color: var(--text);
		transition: border-color 0.15s, background 0.15s;
	}
	.city-card:hover {
		border-color: var(--accent);
		background: var(--bg-card-hover);
		text-decoration: none;
	}
	.city-header {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}
	.city-header h3 {
		font-size: 1.3rem;
		margin: 0;
	}
	.city-comunidad {
		font-size: 0.78rem;
		color: var(--text-dim);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.city-desc {
		font-size: 0.88rem;
		color: var(--text-muted);
		margin: 0 0 1.2rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.city-meta {
		display: flex;
		gap: 2rem;
		border-top: 1px solid var(--border);
		padding-top: 1rem;
	}
	.meta-item {
		display: flex;
		flex-direction: column;
	}
	.meta-value {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--accent);
	}
	.meta-label {
		font-size: 0.72rem;
		color: var(--text-dim);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
</style>
