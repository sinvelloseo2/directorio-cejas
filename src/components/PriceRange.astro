---
interface Props {
	min: number;
	max: number;
	label?: string;
}

const { min, max, label } = Astro.props;
---

<div class="price-range">
	{label && <span class="price-label">{label}</span>}
	<span class="price-value">{min}€ – {max}€</span>
</div>

<style>
	.price-range {
		display: inline-flex;
		align-items: baseline;
		gap: 0.5rem;
	}
	.price-label {
		font-size: 0.78rem;
		color: var(--text-dim);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.price-value {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--accent);
	}
</style>
